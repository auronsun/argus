# =====================================================================
# Argus configuration. Copy to .env and fill in what you have.
# Everything is optional — Argus runs on free data + a single LLM key.
# =====================================================================

# --- LLM provider (pick one or more) ---------------------------------
# The first non-empty key wins, in this priority order:
#   ANTHROPIC > OPENAI > DEEPSEEK > QWEN > OLLAMA (local)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# NVIDIA NIM (https://build.nvidia.com) — OpenAI-compatible
NVIDIA_API_KEY=
NVIDIA_MODEL=minimaxai/minimax-m2.7
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Local Ollama — leave empty unless running it
OLLAMA_HOST=
OLLAMA_MODEL=llama3.1

# --- Market data (optional premium sources) --------------------------
# US — paid / real-time
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

# A-shares — Tushare Pro (https://tushare.pro), needed for >2yr history
TUSHARE_TOKEN=

# HK — Futu OpenAPI / Longbridge (optional)
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=

# --- Server ----------------------------------------------------------
ARGUS_HOST=127.0.0.1
ARGUS_PORT=8765
ARGUS_DB_PATH=./data/argus.sqlite
ARGUS_CACHE_DIR=./data/cache
ARGUS_LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins (Vite dev defaults are auto-added)
ARGUS_CORS_ORIGINS=

# Max parallel analyst LLM calls per committee run.
# 3 = safe on free tiers (NVIDIA NIM / DeepSeek free); raise to 5+ on paid plans.
ARGUS_COMMITTEE_CONCURRENCY=3
